# ─── Base de datos ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/pausa"

# ─── Clerk (autenticación) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Encriptación AES-256 (32 bytes en hex = 64 chars) ─────────────────────
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Google Cloud Speech-to-Text V2 — Chirp 3 (EU / RGPD) ─────────────────
# 1. Crea un proyecto en https://console.cloud.google.com
# 2. Habilita "Cloud Speech-to-Text API"
# 3. Crea un Service Account con rol "Cloud Speech Client"
# 4. Crea un bucket GCS en región EU (para audio >60 s)
# 5. Exporta la clave JSON: cat key.json | tr -d '\n'
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ─── Anthropic (IA en la nube — Claude 3 Haiku) ─────────────────────────────
# Se requiere para generar notas clínicas en Vercel
ANTHROPIC_API_KEY=

# ─── OpenAI (opcional / fallback futuro) ────────────────────────────────────
OPENAI_API_KEY=

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=0.1.0
LOG_LEVEL=debug
NODE_ENV=development
